{
  "name": "dms-monorepo",
  "version": "0.1.0",
  "private": true,
  "description": "AVAIL Data Management System Monorepo",
  "scripts": {
    "build:dms": "cd packages/dms && npm run build",
    "build:server": "cd packages/dms-server && npm run build --if-present",
    "start:server": "cd packages/dms-server && npm start",
    "dev:server": "cd packages/dms-server && npm run dev",
    "publish:dms": "cd packages/dms && npm run publish-it",
    "publish:server": "cd packages/dms-server && npm publish --access public"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/availabs/dms.git"
  },
  "author": "AVAIL",
  "license": "MIT",
  "bugs": {
    "url": "https://github.com/availabs/dms/issues"
  },
  "homepage": "https://github.com/availabs/dms#readme"
}

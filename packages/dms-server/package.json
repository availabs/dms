{
  "name": "@availabs/dms-server",
  "version": "0.1.0",
  "description": "AVAIL Data Management System - Server API",
  "main": "src/index.js",
  "private": false,
  "scripts": {
    "start": "node --max-http-header-size=1048576 --env-file-if-exists=../../../../.env --env-file-if-exists=.env src/index.js",
    "dev": "nodemon --ignore var/ --ignore '*.sqlite' --max-http-header-size=1048576 --env-file-if-exists=../../../../.env --env-file-if-exists=.env src/index.js",
    "test": "node tests/test-sqlite.js && node tests/test-controller.js && node tests/test-graph.js && node tests/test-workflow.js",
    "test:sqlite": "node tests/test-sqlite.js",
    "test:controller": "node tests/test-controller.js",
    "test:graph": "node tests/test-graph.js",
    "test:workflow": "node tests/test-workflow.js",
    "test:uda": "node tests/test-uda.js",
    "test:splitting": "node tests/test-table-splitting.js",
    "test:auth": "node tests/test-auth.js",
    "test:pg:start": "node tests/postgres-docker.js start",
    "test:pg:stop": "node tests/postgres-docker.js stop",
    "test:pg": "node tests/postgres-docker.js run",
    "test:pg:auth": "node tests/postgres-docker.js run tests/test-auth.js",
    "test:db-copy": "node tests/test-db-copy.js",
    "test:sqlite-compat": "node tests/test-sqlite-compat.js",
    "test:sync": "node tests/test-sync.js",
    "test:tasks": "node tests/test-tasks.js",
    "test:upload": "node tests/test-upload-pipeline.js",
    "test:csv-analyzer": "node tests/test-csv-analyzer.js",
    "test:storage": "node tests/test-storage.js",
    "test:datatypes": "node tests/test-datatypes.js",
    "test:migrate-dama": "node tests/test-migrate-dama.js",
    "db:migrate-dama": "node src/scripts/migrate-dama-tasks.js",
    "test:db-cleanup": "node tests/test-db-cleanup.js",
    "test:all": "npm test && npm run test:sync && npm run test:auth && npm run test:pg",
    "db:copy": "node src/scripts/copy-db.js",
    "db:cleanup": "node src/scripts/cleanup-db.js",
    "db:extract-images": "node src/scripts/extract-images.js",
    "db:consolidate-history": "node src/scripts/consolidate-page-history.js"
  },
  "imports": {
    "#db/*.js": "./src/db/*.js",
    "#db/adapters/*.js": "./src/db/adapters/*.js"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/availabs/dms.git",
    "directory": "packages/dms-server"
  },
  "author": "AVAIL",
  "license": "MIT",
  "bugs": {
    "url": "https://github.com/availabs/dms/issues"
  },
  "homepage": "https://github.com/availabs/dms#readme",
  "devDependencies": {
    "nodemon": "^3.1.0"
  },
  "dependencies": {
    "bcryptjs": "^3.0.3",
    "better-sqlite3": "^11.6.0",
    "busboy": "^1.6.0",
    "compression": "^1.8.1",
    "express": "^4.21.0",
    "falcor-json-graph": "^3.0.1",
    "falcor-path-syntax": "0.2.4",
    "falcor-path-utils": "~0.5.0",
    "jsonwebtoken": "^9.0.3",
    "lodash": "^4.17.21",
    "read-excel-file": "^6.0.3",
    "rxjs": "~5.1.1",
    "symbol-observable": "^1.0.4",
    "unzipper": "^0.12.3",
    "ws": "^8.19.0",
    "y-protocols": "^1.0.7",
    "yjs": "^13.6.30"
  },
  "optionalDependencies": {
    "pg": "^8.17.2",
    "pg-copy-streams": "^6.0.0",
    "gdal-async": "^3.9.0",
    "split2": "^4.2.0",
    "@aws-sdk/client-s3": "^3.600.0",
    "sharp": "^0.33.0"
  }
}

# DMS Server — Local Overrides
#
# Most configuration lives in the project root .env file (../../../../.env).
# This file is for server-specific overrides that differ from the root config.
# Values set here take precedence over the root .env.
#
# Copy to .env and edit:  cp .env.example .env

# Server port
# PORT=3001

# DMS database config (filename from src/db/configs/, without .config.json)
# DMS_DB_ENV=dms-sqlite

# Auth database config
# DMS_AUTH_DB_ENV=dms-sqlite

# Request logging (1 = enabled, 0 = disabled)
# DMS_LOG_REQUESTS=0

# JWT secret
# JWT_SECRET=
